SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/callback

# Comma-separated list of allowed frontend origins
FRONTEND_URLS=http://localhost:3000

# Optional explicit redirect target after OAuth
FRONTEND_REDIRECT_URL=http://localhost:3000

# Session configuration
ENV=development
SESSION_TTL_SECONDS=604800
STATE_TTL_SECONDS=600
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=

# Optional Redis session store
# REDIS_URL=redis://localhost:6379/0

# Rate limiting
RATE_LIMIT_GLOBAL=60/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_OPTIMIZE=5/minute
# RATE_LIMIT_REDIS_URL=redis://localhost:6379/1

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Optional JSONL diagnostics path for transition scores per optimize run
# TRANSITION_LOG_PATH=backend/logs/transitions.jsonl

# Durable state database path (runs/presets/schedules/snapshots/etc)
STATE_DB_PATH=backend/data/state.db
STATE_RETENTION_DAYS=30

# Spotify API retry tuning
SPOTIFY_API_RETRIES=4
SPOTIFY_API_BACKOFF=0.8
