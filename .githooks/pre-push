#!/usr/bin/env bash
set -euo pipefail

allow_main_push="${ALLOW_MAIN_PUSH:-0}"

blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ -z "${remote_ref:-}" ]]; then
    continue
  fi
  if [[ "$remote_ref" == "refs/heads/main" && "$allow_main_push" != "1" ]]; then
    blocked=1
  fi
done

if (( blocked == 1 )); then
  echo "pre-push hook: pushing directly to main is blocked by repository policy." >&2
  echo "Use a feature branch + --no-ff merge, or bypass with ALLOW_MAIN_PUSH=1." >&2
  exit 1
fi

